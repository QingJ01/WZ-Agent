# Copy this file to .env or set the variables in PowerShell before launching.
# The GUI can configure most of these values without editing this file.

# Device selection
WZRY_DEVICE_MODE=auto
WZRY_ADB_PATH=adb
WZRY_ADB_DEVICE=

# Runtime controls
WZRY_AI_CONTROL_ENABLED=0
WZRY_DEBUG_WINDOWS=0
WZRY_GUI_MINIMAP_PREVIEW=1
WZRY_DECISION_RECORDING=1
WZRY_DECISION_RECORD_DIR=logs/decision_records

# Touch coordinate mapping for real Android devices
WZRY_TOUCH_SIZE=2400x1080
WZRY_TOUCH_RAW_SIZE=
WZRY_TOUCH_RAW_TRANSFORM=identity

# Optional YOLO model overrides
WZRY_MODEL1_WEIGHTS=models/best_perfect.pt
WZRY_MODEL2_WEIGHTS=models/WZRY-health.pt
WZRY_MODEL3_WEIGHTS=models/wzry.pt

# Optional imitation/self-training policy
WZRY_HUMAN_POLICY_ENABLED=0
WZRY_HUMAN_POLICY_PATH=models/self_policy.pt
WZRY_HUMAN_POLICY_CONFIDENCE=0.80

# ADB movement tuning
WZRY_ADB_MOVE_MODE=motion
WZRY_ADB_MOVE_SWIPE_MS=650
